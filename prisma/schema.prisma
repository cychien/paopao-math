generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  role      UserRole   @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
  sessions  Session[]

  @@map("users")
}

model Purchase {
  id                String         @id @default(cuid())
  userId            String
  email             String
  lemonsqueezyId    String         @unique
  orderNumber       String
  customerId        String?
  status            PurchaseStatus @default(PENDING)
  amount            Int
  currency          String         @default("TWD")
  productName       String         @default("學測總複習班")
  purchasedAt       DateTime       @default(now())
  refundedAt        DateTime?
  hasLifetimeAccess Boolean        @default(true)
  accessGrantedAt   DateTime?
  testMode          Boolean        @default(false)
  webhookProcessed  Boolean        @default(false)
  webhookData       Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("purchases")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  email     String
  token     String    @unique
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum PurchaseStatus {
  PENDING
  ACTIVE
  REFUNDED
}

enum UserRole {
  USER
  ADMIN
}

model Lesson {
  id          String    @id @default(cuid())
  name        String
  description String?
  slug        String    @unique
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  chapters    Chapter[]

  @@map("lessons")
}

model Chapter {
  id        String     @id @default(cuid())
  name      String
  slug      String
  order     Int        @default(0)
  lessonId  String
  lesson    Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  teachings Teaching[]
  exams     Exam[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([lessonId, slug])
  @@map("chapters")
}

model Teaching {
  id        String   @id @default(cuid())
  videoId   String
  duration  Int      // 秒數
  order     Int      @default(0)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teachings")
}

model Exam {
  id        String   @id @default(cuid())
  videoId   String
  duration  Int      // 秒數
  order     Int      @default(0)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exams")
}

model EntranceExam {
  id          String         @id @default(cuid())
  title       String
  year        Int
  subject     String
  type        String         // A, B 等
  description String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  questions   ExamQuestion[]

  @@map("entrance_exams")
}

model ExamQuestion {
  id                String       @id @default(cuid())
  title             String
  fileType          String       // pdf, video 等
  fileUrl           String?      // 用於 PDF 等檔案
  downloadFilename  String?      // 下載檔案名稱
  questionType      String       // single-choice, multiple-choice, fill-in
  order             Int          @default(0)
  examId            String
  exam              EntranceExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers           ExamAnswer[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@map("exam_questions")
}

model ExamAnswer {
  id         String       @id @default(cuid())
  title      String
  fileType   String       // video, pdf 等
  videoId    String?      // 用於影片
  duration   Int?         // 影片時長（秒）
  fileUrl    String?      // 用於其他檔案類型
  order      Int          @default(0)
  questionId String
  question   ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("exam_answers")
}
